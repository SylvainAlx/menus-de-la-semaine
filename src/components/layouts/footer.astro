---
const currentYear = new Date().getFullYear();
---

<footer class="main-footer">
  <div class="footer-inner">
    <div class="footer-home">
      <a href="https://apps.alx-solutions-numeriques.fr/" class="footer-link">
        <span class="link-icon">←</span> ALX's Apps
      </a>
    </div>
    <div class="footer-info">
      <p>© {currentYear} <strong>Les Menus de la Semaine</strong></p>
    </div>
    <div class="footer-credits">
      <p>
        Conçu avec ❤️ par
        <a
          href="https://alx-solutions-numeriques.fr/"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-link"
        >
          Sylvain Alexandre
          <span class="link-icon">↗</span>
        </a>
      </p>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    background: var(--card-bg);
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    padding: 24px;
    margin-top: 48px;
    backdrop-filter: blur(12px);
    width: 100%;
  }

  .footer-inner {
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .main-footer p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .footer-info strong {
    color: var(--primary);
  }

  .footer-credits p {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .footer-link {
    color: var(--text-main);
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
    border-bottom: 2px solid transparent;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .footer-link:hover {
    color: var(--primary);
    border-bottom-color: var(--primary);
  }

  .link-icon {
    font-size: 0.7rem;
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
