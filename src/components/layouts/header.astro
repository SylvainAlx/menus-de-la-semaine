---
import Load from "../ui/Load.svg";
import Save from "../ui/Save.svg";
---

<header>
  <button
    id="btn-sauvegarder"
    class="side-panel-toggle-left save-toggle-btn"
    aria-label="Enregistrer les données"
    title="Enregistrer les données"
  >
    <Save />
  </button>
  <h1>Les menus de la semaine</h1>
  <button
    id="btn-charger"
    class="side-panel-toggle-left charger-toggle-btn"
    aria-label="Charger les données"
    title="Charger les données"
  >
    <Load />
  </button>
  <button
    id="btn-reset"
    class="side-panel-toggle-left reset-toggle-btn"
    aria-label="Réinitialiser les données"
    title="Réinitialiser les données"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="lucide lucide-rotate-ccw"
      ><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path
        d="M3 3v5h5"></path></svg
    >
  </button>
</header>
<script>
  import { utilisateur } from "../../store.ts";

  const btn = document.getElementById("btn-charger");
  btn?.addEventListener("click", async () => {
    const u = utilisateur.get();
    await u.chargerDataDepuisJson();
    utilisateur.set(u.clone());
  });

  const btn2 = document.getElementById("btn-sauvegarder");
  btn2?.addEventListener("click", async () => {
    await utilisateur.get().telechargerDataEnJson();
  });

  const btn3 = document.getElementById("btn-reset");
  btn3?.addEventListener("click", async () => {
    if (window.confirm("Voulez-vous vraiment réinitialiser les données ?")) {
      const u = utilisateur.get();
      u.reset();
      utilisateur.set(u.clone());
    }
  });
</script>
