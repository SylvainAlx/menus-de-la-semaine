<header>
  <button
    id="btn-sauvegarder"
    class="side-panel-toggle-left save-toggle-btn"
    aria-label="Enregistrer les données"
    title="Enregistrer les données"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="lucide lucide-save"
      ><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"
      ></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline
        points="7 3 7 8 15 8"></polyline></svg
    >
  </button>
  <h1>Les menus de la semaine</h1>
  <button
    id="btn-charger"
    class="side-panel-toggle-left charger-toggle-btn"
    aria-label="Charger les données"
    title="Charger les données"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="lucide lucide-folder-open"
      ><path
        d="m6 14 1.45-2.9a2 2 0 0 1 1.79-1.1H20a2 2 0 0 1 1.94 2.5l-1.55 6a2 2 0 0 1-1.94 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.69.9H18a2 2 0 0 1 2 2v2"
      ></path></svg
    >
  </button>
  <button
    id="btn-reset"
    class="side-panel-toggle-left reset-toggle-btn"
    aria-label="Réinitialiser les données"
    title="Réinitialiser les données"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="lucide lucide-rotate-ccw"
      ><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path
        d="M3 3v5h5"></path></svg
    >
  </button>
</header>
<script>
  import { utilisateur } from "../../store.ts";

  const btn = document.getElementById("btn-charger");
  btn?.addEventListener("click", async () => {
    const u = utilisateur.get();
    await u.chargerDataDepuisJson();
    utilisateur.set(u.clone());
  });

  const btn2 = document.getElementById("btn-sauvegarder");
  btn2?.addEventListener("click", async () => {
    await utilisateur.get().telechargerDataEnJson();
  });

  const btn3 = document.getElementById("btn-reset");
  btn3?.addEventListener("click", async () => {
    if (window.confirm("Voulez-vous vraiment réinitialiser les données ?")) {
      const u = utilisateur.get();
      u.reset();
      utilisateur.set(u.clone());
    }
  });
</script>
